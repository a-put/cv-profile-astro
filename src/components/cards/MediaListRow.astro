---
interface Props {
  title: string;
  source?: string;
  date?: string;
  url?: string;
}

const { title, source, date, url } = Astro.props;
const meta = [source, date].filter(Boolean).join(' · ');
---

<a class="media-list-item" href={url || '#'} target={url ? '_blank' : undefined} rel={url ? 'noopener noreferrer' : undefined}>
  <span class="media-list-title">{title}</span>
  <span class="media-list-meta">{meta}{url && <span class="media-arrow"> ↗</span>}</span>
</a>
