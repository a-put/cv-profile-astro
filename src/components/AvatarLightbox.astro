---
interface Props {
  avatar?: string;
}

const { avatar = 'assets/avatar.jpg' } = Astro.props;
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
---

<div id="avatar-lightbox" role="dialog" aria-modal="true" aria-label="Profile photo enlarged">
  <div class="lb-backdrop"></div>
  <img class="lb-img" src={`${base}/${avatar}`} alt="Profile photo enlarged" />
</div>
