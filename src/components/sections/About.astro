---
import EducationCard from '../cards/EducationCard.astro';

interface Props {
  about: string;
  education: Array<{
    degree: string;
    institution: string;
    period: string;
    location: string;
    note?: string;
  }>;
  explainer?: {
    headline?: string;
    body?: string;
  };
  availability?: {
    status?: string;
    roles?: string[];
    locations?: string[];
    visa?: string;
    relocation?: string;
  };
  recognition?: Array<{
    title: string;
    year: string;
    url?: string;
    highlight?: boolean;
  }>;
}

const { about, education, explainer, availability, recognition } = Astro.props;
const highlights = recognition?.filter(r => r.highlight) ?? [];

// Replicate the markdown-bold parsing from main.js
const aboutHtml = about
  .replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;')
  .replace(/\*\*(.*?)\*\*/g, '<strong>$1</strong>')
  .replace(/\n\n/g, '<br><br>');

const hasExplainer = explainer && (explainer.headline || explainer.body);
---

<section id="tab-about" class="tab-section">
  <h2 class="section-title">About</h2>

  {hasExplainer && (
    <div class="explainer-card">
      {explainer!.headline && <div class="explainer-headline">{explainer!.headline}</div>}
      {explainer!.body && <p class="explainer-body">{explainer!.body}</p>}
    </div>
  )}

  <p id="about-text" class="text-sm leading-relaxed" style="color: var(--text-secondary); max-width: 60ch;" set:html={aboutHtml} />

  {availability && (
    <div class="availability-block">
      <div class="availability-header">
        <span class="availability-dot"></span>
        <span class="availability-status">{availability.status}</span>
      </div>
      {availability.roles && availability.roles.length > 0 && (
        <div class="availability-roles">
          {availability.roles.map(role => (
            <span class="availability-pill">{role}</span>
          ))}
        </div>
      )}
      {availability.locations && availability.locations.length > 0 && (
        <div class="availability-meta">
          <span class="availability-label">Locations:</span> {availability.locations.join(' · ')}
        </div>
      )}
      {availability.visa && (
        <div class="availability-meta">
          <span class="availability-label">Visa:</span> {availability.visa}
        </div>
      )}
    </div>
  )}

  {highlights.length > 0 && (
    <div class="highlight-badges">
      {highlights.map(h => (
        <span class="highlight-badge">
          <span class="highlight-badge-icon">&#127942;</span>
          <span>{h.title} ({h.year})</span>
        </span>
      ))}
    </div>
  )}

  <p class="subsection-label">Education</p>
  <div class="flex flex-col gap-3">
    {education.map(item => (
      <EducationCard
        degree={item.degree}
        institution={item.institution}
        period={item.period}
        location={item.location}
        note={item.note}
      />
    ))}
  </div>
</section>
