---
interface Props {
  skills: Record<string, string[]>;
  skillConnections?: string[][];
}

const { skills, skillConnections } = Astro.props;

// Data island for the client-side canvas script
const skillsData = JSON.stringify({ skills, skillConnections });
---

<section id="tab-skills" class="tab-section hidden">
  <h2 class="section-title">Skills</h2>
  <div id="skills-graph-wrap">
    <canvas id="skills-graph" aria-label="Interactive skills network graph"></canvas>
  </div>

  <!-- Static fallback for prefers-reduced-motion -->
  <noscript>
    <div class="flex flex-col gap-6">
      {Object.entries(skills).map(([group, items]) => (
        <div>
          <div class="skill-group-title">{group}</div>
          <div>
            {items.map(s => <span class="skill-tag">{s}</span>)}
          </div>
        </div>
      ))}
    </div>
  </noscript>

  <script id="skills-data" type="application/json" set:html={skillsData} />
</section>
