---
import PublicationCard from '../cards/PublicationCard.astro';

interface Pub {
  authors: string;
  title: string;
  corresponding: boolean;
  journal: string;
  ref: string;
  year: string;
  doi?: string;
  pdf?: string;
  badges: string[];
  layman?: string;
  image?: string;
  featured?: boolean;
}

interface Props {
  publications: Pub[];
  orcid?: string;
  googleScholar?: string;
}

const { publications, orcid, googleScholar } = Astro.props;
const featured = publications.filter(p => p.featured);
const other = publications.filter(p => !p.featured);
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
---

<section id="tab-publications" class="tab-section hidden">
  <h2 class="section-title">Publications</h2>

  <div class="flex flex-wrap gap-3 mb-5">
    {orcid && (
      <a href={orcid} target="_blank" rel="noopener noreferrer" class="pub-profile-btn">
        <img src={`${base}/orcid.png`} alt="ORCID" /><span>ORCID</span>
      </a>
    )}
    {googleScholar && (
      <a href={googleScholar} target="_blank" rel="noopener noreferrer" class="pub-profile-btn">
        <img src={`${base}/GoogleScholar.png`} alt="Google Scholar" /><span>Google Scholar</span>
      </a>
    )}
  </div>

  <p class="text-xs mb-5" style="color: var(--text-tertiary);">
    * co-first author &nbsp;·&nbsp; <sup>†</sup> corresponding author
  </p>

  {featured.length > 0 && (
    <p class="subsection-label" style="margin-top: 0;">Featured</p>
    <div class="flex flex-col gap-3">
      {featured.map(pub => (
        <PublicationCard
          authors={pub.authors}
          title={pub.title}
          corresponding={pub.corresponding}
          journal={pub.journal}
          ref={pub.ref}
          year={pub.year}
          doi={pub.doi}
          pdf={pub.pdf}
          badges={pub.badges}
          layman={pub.layman}
          image={pub.image}
          featured={true}
        />
      ))}
    </div>
  )}

  {other.length > 0 && (
    <details class="pub-other-details">
      <summary class="pub-other-summary">
        Show {other.length} more publication{other.length > 1 ? 's' : ''}
      </summary>
      <div class="flex flex-col gap-3 mt-3">
        {other.map(pub => (
          <PublicationCard
            authors={pub.authors}
            title={pub.title}
            corresponding={pub.corresponding}
            journal={pub.journal}
            ref={pub.ref}
            year={pub.year}
            doi={pub.doi}
            pdf={pub.pdf}
            badges={pub.badges}
            layman={pub.layman}
            image={pub.image}
          />
        ))}
      </div>
    </details>
  )}
</section>
