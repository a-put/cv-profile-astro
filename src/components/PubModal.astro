---
// Publication explainer modal — shell only, populated by client JS
---

<div id="pub-modal" aria-modal="true" role="dialog">
  <button id="pub-modal-close" aria-label="Close">&times;</button>
  <div id="pub-modal-card" class="pub-modal-card">
    <div class="pub-modal-text-panel">
      <span id="pm-journal" class="pub-modal-journal-label"></span>
      <div id="pm-title" class="pub-modal-title"></div>
      <p id="pm-layman" class="pub-modal-layman"></p>
    </div>
    <div id="pm-img-wrap" class="pub-modal-img-wrap">
      <img id="pm-img" src="" alt="Publication illustration" />
    </div>
  </div>
</div>
